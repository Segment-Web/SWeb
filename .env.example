# Local development works with these defaults.
NODE_ENV=development
HOST=0.0.0.0
PORT=3000

# Production public address and accepted browser origins.
PUBLIC_URL=https://chat.example.com
ALLOWED_ORIGINS=https://chat.example.com
TRUST_PROXY=1

# Connection and transport safety limits.
MAX_CONNECTIONS=500
MAX_CONNECTIONS_PER_IP=20
MAX_WS_PAYLOAD=16777216
MESSAGES_PER_MINUTE=240
WS_HEARTBEAT_MS=30000
SHUTDOWN_TIMEOUT_MS=10000

# Accounts and email sign-in. Generate both secrets with: openssl rand -hex 32
POSTGRES_PASSWORD=replace-with-a-long-random-password
DATABASE_URL=postgresql://segment:replace-with-a-long-random-password@postgres:5432/segment
AUTH_SECRET=replace-with-a-long-random-secret
AUTH_CODE_TTL_MS=600000
AUTH_SESSION_TTL_MS=2592000000
AUTH_MAX_AVATAR_BYTES=524288

# Rooms and encrypted attachment storage.
ROOM_INVITE_TTL_MS=604800000
FILE_DIR=/data/files
FILE_MAX_BYTES=104857600
# Zero keeps encrypted blobs indefinitely.
FILE_TTL_MS=0

# Any SMTP provider. Port 465 uses implicit TLS; port 587 uses STARTTLS.
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=0
SMTP_USER=
SMTP_PASS=
SMTP_FROM=Segment <noreply@segmnt.org>
