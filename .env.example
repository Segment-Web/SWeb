# Local development works with these defaults.
NODE_ENV=development
HOST=0.0.0.0
PORT=3000

# Production public address and accepted browser origins.
PUBLIC_URL=https://chat.example.com
ALLOWED_ORIGINS=https://chat.example.com
TRUST_PROXY=1

# Early-beta safety limits. Attachments are currently transported over WebSocket.
MAX_CONNECTIONS=500
MAX_CONNECTIONS_PER_IP=20
MAX_WS_PAYLOAD=16777216
MESSAGES_PER_MINUTE=240
WS_HEARTBEAT_MS=30000
SHUTDOWN_TIMEOUT_MS=10000
